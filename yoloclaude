#!/bin/bash
# yoloclaude — Sandboxed Claude Code with Chrome DevTools.
#
# --dangerously-skip-permissions auto-approves every tool call, including bash.
# A stray "rm -rf ~" doesn't need sudo — you own your home directory. This
# script runs Claude inside a disposable Docker container so the worst it can
# do is trash /workspace, which is a mounted copy of your project. Worst case:
# git checkout to recover.
#
# Your project is mounted at /workspace, so CLAUDE.md is picked up automatically.
#
# SETUP:
#   1. Docker running
#   2. bash chromex.sh                                     (Chrome on port 9224)
#
# USAGE:
#   ./yoloclaude                     # interactive
#   ./yoloclaude "fill out the app"  # with a prompt

set -euo pipefail

# Pull the full OAuth credentials from macOS Keychain where Claude Code stores
# them. The keychain entry is a JSON blob under "Claude Code-credentials" —
# we pass it into the container to write as ~/.claude/.credentials.json.
CLAUDE_CREDENTIALS=$(security find-generic-password -s "Claude Code-credentials" -w)
export CLAUDE_CREDENTIALS

# Inline image build — no Dockerfile to maintain
# --quiet suppresses build log spam
docker build --quiet -t claude-sandbox - <<'DOCKERFILE'
FROM node:22
RUN apt-get update && apt-get install -y jq && rm -rf /var/lib/apt/lists/*
RUN npm install -g @anthropic-ai/claude-code
# Claude refuses --dangerously-skip-permissions as root
RUN useradd -m claude
USER claude
WORKDIR /workspace
DOCKERFILE

# Write a temporary entrypoint script that sets up config files and launches
# Claude. This avoids nested heredoc/quoting hell in bash -c.
ENTRYPOINT=$(mktemp)
CNAME="yolo-$$"
trap "docker kill $CNAME 2>/dev/null; rm -f $ENTRYPOINT" EXIT

cat > "$ENTRYPOINT" <<'ENTRY'
#!/bin/bash
set -euo pipefail

# Write config files so Claude launches with zero interactive prompts.
#   ~/.claude.json          — skips onboarding and workspace trust dialog
#   ~/.claude/settings.json — skips bypass-permissions warning, sets effort level
#   ~/.claude/.credentials.json — OAuth tokens from macOS Keychain
mkdir -p ~/.claude

echo "$CLAUDE_CREDENTIALS" > ~/.claude/.credentials.json
chmod 600 ~/.claude/.credentials.json

echo '{"hasCompletedOnboarding":true,"hasTrustDialogHooksAccepted":true,"effortCalloutDismissed":true,"lastOnboardingVersion":"2.1.62","numStartups":1,"projects":{"/workspace":{"hasTrustDialogAccepted":true}}}' > ~/.claude.json

echo '{"skipDangerousModePermissionPrompt":true,"effortLevel":"high"}' > ~/.claude/settings.json

# Chrome runs on the host Mac (port 9224 via chromex.sh). We resolve
# host.docker.internal to its IP because Chrome's DevTools server rejects
# HTTP requests with non-IP, non-localhost Host headers (security check
# since Chrome 66). Using the raw IP makes the Host header pass validation.
CHROME_IP=$(getent hosts host.docker.internal | awk '{print $1}')
claude mcp add chrome-devtools -- npx -y chrome-devtools-mcp@latest --browserUrl "http://${CHROME_IP}:9224"

# Launch Claude
if [ $# -gt 0 ]; then
  exec claude --dangerously-skip-permissions -p "$*" --verbose --output-format stream-json \
    | jq --unbuffered -rj '
        select(.type == "assistant") | .message.content[]? |
        if .type == "text" then .text
        elif .type == "tool_use" then
          "\n--- \(.name)" +
          (if .input.command then ": " + .input.command
           elif .input.file_path then ": " + .input.file_path
           elif .input.pattern then ": " + .input.pattern
           else "" end) +
          " ---\n"
        elif .type == "thinking" then "\n--- Thinking ---\n\(.thinking)\n"
        else empty end
      '
else
  exec claude --dangerously-skip-permissions
fi
ENTRY
chmod +x "$ENTRYPOINT"

# Container is removed on exit (--rm). Nothing persists.
# Backgrounded so `wait` is interruptible by signals; EXIT trap docker-kills it.
docker run --rm --init --name "$CNAME" \
  -v "$(pwd)":/workspace \
  -v "$ENTRYPOINT":/entrypoint.sh:ro \
  -e CLAUDE_CREDENTIALS \
  --add-host=host.docker.internal:host-gateway \
  claude-sandbox \
  bash /entrypoint.sh "$@" &
wait $!
