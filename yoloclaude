#!/bin/bash
# yoloclaude — Sandboxed Claude Code with Chrome DevTools
#
# This script serves double duty: on the host it builds and launches a Docker
# container; inside the container (detected via SANDBOXED) it configures
# and runs Claude. One file, no temp files.
#
# SETUP:
#   1. Docker running
#   2. bash chromex.sh                                     (Chrome on port 9224)
#
# USAGE:
#   ./yoloclaude                     # interactive
#   ./yoloclaude "fill out the app"  # single prompt

set -euo pipefail

# Pipe stream-json through this to get clean, readable text.
humanize_stream() {
  jq --unbuffered -rj '
    def tool_detail: (.input | .command // .file_path // .pattern | strings | ": \(.)") // "";
    def render_tool:     "\n--- \(.name)\(tool_detail) ---\n";
    def render_thinking: "\n--- Thinking ---\n\(.thinking)\n";
    select(.type == "assistant") | .message.content[]? |
    if   .type == "text"     then .text
    elif .type == "tool_use" then render_tool
    elif .type == "thinking" then render_thinking
    else empty end
  '
}

# == SANDBOX ===================================================================
# When docker run re-invokes this script inside the container, SANDBOXED is set.

if [ -n "${SANDBOXED:-}" ]; then
  # ~/.claude/.credentials.json = auth token (from host keychain via env var).
  # ~/.claude.json = skip onboarding dialogs. ~/.claude/settings.json = yolo mode.
  mkdir -p ~/.claude
  echo "$CLAUDE_CREDENTIALS" > ~/.claude/.credentials.json
  chmod 600 ~/.claude/.credentials.json
  echo '{"hasCompletedOnboarding":true,"hasTrustDialogHooksAccepted":true,"effortCalloutDismissed":true,"lastOnboardingVersion":"2.1.62","numStartups":1,"projects":{"/workspace":{"hasTrustDialogAccepted":true}}}' > ~/.claude.json
  echo '{"skipDangerousModePermissionPrompt":true,"effortLevel":"high"}' > ~/.claude/settings.json

  # Resolve host.docker.internal to an IP — Chrome's DevTools rejects non-IP
  # Host headers (since Chrome 66), so we need the raw IP for validation.
  CHROME_IP=$(getent hosts host.docker.internal | awk '{print $1}')
  claude mcp add chrome-devtools -- npx -y chrome-devtools-mcp@latest --browserUrl "http://${CHROME_IP}:9224"

  case $# in
    0) claude --dangerously-skip-permissions ;;
    *) claude --dangerously-skip-permissions -p "$*" --output-format stream-json | humanize_stream ;;
  esac
  exit 0
fi



# == SANDBOX_BUILD ============================================================
# Builds the Docker image and launches the container on the host.

# Pull Claude's auth token from the macOS keychain.
CLAUDE_CREDENTIALS=$(security find-generic-password -s "Claude Code-credentials" -w)
export CLAUDE_CREDENTIALS

# Inline Dockerfile: Node 22, Claude Code, Python venv, optional pip requirements.
DOCKERFILE='
FROM node:22
RUN apt-get update && apt-get install -y jq python3 python3-pip python3-venv && rm -rf /var/lib/apt/lists/*
RUN npm install -g @anthropic-ai/claude-code
RUN useradd -m claude
USER claude
RUN python3 -m venv /home/claude/venv
ENV PATH="/home/claude/venv/bin:$PATH"
ARG REQUIREMENTS
RUN if [ -n "$REQUIREMENTS" ]; then \
      printf "%s\n" "$REQUIREMENTS" > /tmp/requirements.txt \
      && pip install -r /tmp/requirements.txt \
      && rm /tmp/requirements.txt; \
    fi
WORKDIR /workspace
'

# Build the image, injecting requirements.txt if present.
docker build --quiet \
  --build-arg REQUIREMENTS="$(cat requirements.txt 2>/dev/null)" \
  -t claude-sandbox - <<<"$DOCKERFILE"

# Run the container, re-invoking this script as the entrypoint.
# -it: PTY so Ctrl+C sends SIGINT to the whole process group.
# --init: tini forwards SIGTERM on docker stop.
docker run -it --rm --init \
  -v "$(pwd)":/workspace \
  -v "$(realpath "$0")":/entrypoint.sh:ro \
  -e CLAUDE_CREDENTIALS \
  -e SANDBOXED=1 \
  -e TERM="${TERM:-xterm-256color}" \
  -e COLORTERM="${COLORTERM:-truecolor}" \
  --add-host=host.docker.internal:host-gateway \
  claude-sandbox \
  bash /entrypoint.sh "$@"
